generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Course {
  id                 String           @id @default(cuid())
  instructorId       String           @map("instructor_id")
  title              String
  description        String
  shortDescription   String?          @map("short_description")
  slug               String           @unique
  thumbnailUrl       String           @map("thumbnail_url")
  previewVideo       String?          @map("preview_video")
  price              Decimal          @db.Decimal(10, 2)
  compareAtPrice     Decimal?         @map("compare_at_price") @db.Decimal(10, 2)
  currency           Currency         @default(EGP)
  level              CourseLevel      @default(BEGINNER)
  status             CourseStatus     @default(DRAFT)
  visibility         CourseVisibility @default(PRIVATE)
  isFeatured         Boolean          @default(false) @map("is_featured")
  requirements       String[]
  objectives         String[]
  targetAudience     String[]         @map("target_audience")
  tags               String[]
  metaTitle          String?          @map("meta_title")
  metaDescription    String?          @map("meta_description")
  certificateEnabled Boolean          @default(true) @map("certificate_enabled")
  maxStudents        Int?             @map("max_students")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  publishedAt        DateTime?        @map("published_at")
  pathId             String           @map("path_id")
  trackId            String?          @map("track_id")
  duration           Int?
  cartItems          CartItem[]
  coupons            CouponCourse[]
  instructor         User             @relation("CourseInstructor", fields: [instructorId], references: [id])
  path               Path             @relation(fields: [pathId], references: [id])
  track              Track?           @relation(fields: [trackId], references: [id])
  orderItems         OrderItem[]
  reviews            Review[]
  sections           Section[]
  enrollments        Enrollment[]
  prerequisites      Course[]         @relation("CoursePrerequisites")
  requiredFor        Course[]         @relation("CoursePrerequisites")

  @@index([instructorId])
  @@index([status])
  @@index([visibility])
  @@index([pathId])
  @@index([trackId])
  @@index([slug])
  @@index([isFeatured])
  @@map("courses")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Section {
  id          String    @id @default(cuid())
  courseId    String    @map("course_id")
  title       String
  description String?
  position    Int
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lectures    Lecture[]
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([position])
  @@map("sections")
}

model Lecture {
  id            String       @id @default(cuid())
  sectionId     String       @map("section_id")
  title         String
  description   String?
  type          LectureType  @default(VIDEO)
  content       String?
  videoUrl      String?      @map("video_url")
  videoDuration Int?         @map("video_duration")
  position      Int
  isPublished   Boolean      @default(false) @map("is_published")
  isFree        Boolean      @default(false) @map("is_free")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  muxPlaybackId String?      @map("mux_playback_id")
  attachments   Attachment[]
  section       Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress      Progress[]

  @@index([sectionId])
  @@index([position])
  @@map("lectures")
}

model Attachment {
  id             String         @id @default(cuid())
  lectureId      String         @map("lecture_id")
  name           String
  description    String?
  type           AttachmentType
  url            String
  content        String?
  fileSize       Int?           @map("file_size")
  mimeType       String?        @map("mime_type")
  isDownloadable Boolean        @default(true) @map("is_downloadable")
  position       Int            @default(0)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  lecture        Lecture        @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@index([lectureId])
  @@index([type])
  @@index([position])
  @@index([lectureId, position])
  @@map("attachments")
}

model Path {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  tagline          String?
  shortDescription String?       @map("short_description")
  description      String
  thumbnailUrl     String        @map("thumbnail_url")
  category         PathCategory
  icon             String?
  isPublished      Boolean       @default(true) @map("is_published")
  sortOrder        Int           @default(0) @map("sort_order")
  metaTitle        String?       @map("meta_title")
  metaDescription  String?       @map("meta_description")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  pathSections     PathSection[]
  courses          Course[]
  tracks           Track[]

  @@index([slug])
  @@index([category])
  @@index([isPublished])
  @@map("paths")
}

model PathSection {
  id      String          @id @default(cuid())
  pathId  String
  type    PathSectionType
  content String
  order   Int
  trackId String?
  path    Path            @relation(fields: [pathId], references: [id])
  track   Track?          @relation(fields: [trackId], references: [id])
}

model Track {
  id               String        @id @default(cuid())
  pathId           String        @map("path_id")
  title            String
  slug             String        @unique
  shortDescription String        @map("short_description")
  description      String
  thumbnailUrl     String?       @map("thumbnail_url")
  category         PathCategory
  icon             String?
  isPublished      Boolean       @default(true) @map("is_published")
  sortOrder        Int           @default(0) @map("sort_order")
  metaTitle        String?       @map("meta_title")
  metaDescription  String?       @map("meta_description")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  sections         PathSection[]
  courses          Course[]
  path             Path          @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([pathId])
  @@index([category])
  @@index([isPublished])
  @@map("tracks")
}

model User {
  id                            String                   @id @default(cuid())
  email                         String                   @unique
  password                      String?
  passwordChangedAt             DateTime?                @map("password_changed_at")
  firstName                     String?                  @map("first_name")
  lastName                      String?                  @map("last_name")
  profilePicture                String?                  @map("profile_picture")
  bio                           String?
  role                          Role                     @default(STUDENT)
  isEmailVerified               Boolean                  @default(false) @map("is_email_verified")
  isActive                      Boolean                  @default(true) @map("is_active")
  lastLoginAt                   DateTime?                @map("last_login_at")
  failedLoginCount              Int                      @default(0) @map("failed_login_count")
  lockedUntil                   DateTime?                @map("locked_until")
  emailVerifyToken              String?                  @unique @map("email_verify_token")
  emailVerifyExpires            DateTime?                @map("email_verify_expires")
  verificationResendCount       Int                      @default(0) @map("verification_resend_count")
  verificationResendLastAttempt DateTime?                @map("verification_resend_last_attempt")
  resetPasswordToken            String?                  @unique @map("reset_password_token")
  resetPasswordExpires          DateTime?                @map("reset_password_expires")
  passwordResetRequestCount     Int                      @default(0) @map("password_reset_request_count")
  passwordResetLastAttempt      DateTime?                @map("password_reset_last_attempt")
  passwordSetupRequestCount     Int                      @default(0) @map("password_setup_request_count")
  passwordSetupLastAttempt      DateTime?                @map("password_setup_last_attempt")
  timezone                      String?                  @default("UTC")
  language                      String?                  @default("en")
  oauthProvider                 String?                  @map("oauth_provider")
  oauthProviderId               String?                  @map("oauth_provider_id")
  createdAt                     DateTime                 @default(now()) @map("created_at")
  updatedAt                     DateTime                 @updatedAt @map("updated_at")
  accounts                      Account[]
  cart                          Cart?
  bookings                      ConsultationBooking[]
  instructedCourses             Course[]                 @relation("CourseInstructor")
  enrollments                   Enrollment[]
  googleCalendarToken           GoogleCalendarToken?
  availabilities                InstructorAvailability[]
  orders                        Order[]
  reviews                       Review[]
  sessions                      Session[]

  @@unique([oauthProvider, oauthProviderId])
  @@index([email])
  @@index([emailVerifyToken])
  @@index([resetPasswordToken])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  accessToken  String   @unique @map("access_token")
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accessToken])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

model Enrollment {
  id          String           @id @default(cuid())
  studentId   String           @map("student_id")
  courseId    String           @map("course_id")
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now()) @map("enrolled_at")
  completedAt DateTime?        @map("completed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  student     User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress    Progress[]

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@index([status])
  @@map("enrollments")
}

model Progress {
  id             String     @id @default(cuid())
  enrollmentId   String     @map("enrollment_id")
  lectureId      String     @map("lecture_id")
  isCompleted    Boolean    @default(false) @map("is_completed")
  completedAt    DateTime?  @map("completed_at")
  lastAccessedAt DateTime   @default(now()) @map("last_accessed_at")
  timeSpent      Int        @default(0) @map("time_spent")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lectures       Lecture    @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lectureId])
  @@index([enrollmentId])
  @@index([lectureId])
  @@map("progress")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique @map("user_id")
  couponId  String?    @map("coupon_id")
  subtotal  Decimal    @default(0) @db.Decimal(10, 2)
  discount  Decimal    @default(0) @db.Decimal(10, 2)
  total     Decimal    @default(0) @db.Decimal(10, 2)
  currency  Currency   @default(EGP)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  items     CartItem[]
  coupon    Coupon?    @relation(fields: [couponId], references: [id])
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([couponId])
  @@map("carts")
}

model CartItem {
  id       String   @id @default(cuid())
  cartId   String   @map("cart_id")
  courseId String   @map("course_id")
  price    Decimal  @db.Decimal(10, 2)
  currency Currency @default(EGP)
  addedAt  DateTime @default(now()) @map("added_at")
  cart     Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([cartId, courseId])
  @@index([cartId])
  @@index([courseId])
  @@map("cart_items")
}

model Coupon {
  id             String         @id @default(cuid())
  code           String         @unique
  description    String?
  type           CouponType
  value          Decimal        @db.Decimal(10, 2)
  maxUses        Int?           @map("max_uses")
  usedCount      Int            @default(0) @map("used_count")
  maxUsesPerUser Int            @default(1) @map("max_uses_per_user")
  minOrderAmount Decimal?       @map("min_order_amount") @db.Decimal(10, 2)
  startsAt       DateTime?      @map("starts_at")
  expiresAt      DateTime?      @map("expires_at")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  carts          Cart[]
  courses        CouponCourse[]
  orders         Order[]

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model CouponCourse {
  id        String   @id @default(cuid())
  couponId  String   @map("coupon_id")
  courseId  String   @map("course_id")
  createdAt DateTime @default(now()) @map("created_at")
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([couponId, courseId])
  @@index([couponId])
  @@index([courseId])
  @@map("coupon_courses")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @map("order_number")
  userId          String      @map("user_id")
  subtotalCents   Int         @map("subtotal_cents")
  discountCents   Int         @default(0) @map("discount_cents")
  taxCents        Int         @default(0) @map("tax_cents")
  totalCents      Int         @map("total_cents")
  currency        Currency    @default(EGP)
  status          OrderStatus @default(PENDING)
  couponId        String?     @map("coupon_id")
  couponCode      String?     @map("coupon_code")
  paymentId       String?     @unique @map("payment_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  completedAt     DateTime?   @map("completed_at")
  stripeSessionId String?     @map("stripe_session_id")
  items           OrderItem[]
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  payment         Payment?    @relation(fields: [paymentId], references: [id])
  user            User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String   @map("order_id")
  courseId   String   @map("course_id")
  priceCents Int      @map("price_cents")
  currency   Currency @default(EGP)
  course     Course   @relation(fields: [courseId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([courseId])
  @@map("order_items")
}

model Payment {
  id                    String               @id @default(cuid())
  stripePaymentIntentId String?              @unique @map("stripe_payment_intent_id")
  stripeSessionId       String?              @map("stripe_session_id")
  stripeCustomerId      String?              @map("stripe_customer_id")
  provider              PaymentProvider      @default(STRIPE)
  providerTransactionId String?              @map("provider_transaction_id")
  providerMetadata      Json?                @map("provider_metadata")
  amountCents           Int                  @map("amount_cents")
  currency              Currency             @default(EGP)
  status                PaymentStatus        @default(PENDING)
  paymentMethod         String?
  last4                 String?
  brand                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  paidAt                DateTime?
  consultationBooking   ConsultationBooking?
  order                 Order?
  refunds               Refund[]
}

model Refund {
  id               String       @id @default(cuid())
  paymentId        String       @map("payment_id")
  amountCents      Int          @map("amount_cents")
  currency         Currency     @default(EGP)
  reason           String?
  status           RefundStatus @default(PENDING)
  providerRefundId String?      @map("provider_refund_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  processedAt      DateTime?    @map("processed_at")
  payment          Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([status])
  @@map("refunds")
}

model Review {
  id        String   @id @default(cuid())
  courseId  String   @map("course_id")
  userId    String   @map("user_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

model InstructorAvailability {
  id           String                @id @default(cuid())
  instructorId String                @map("instructor_id")
  dayOfWeek    Int                   @map("day_of_week")
  startTime    String                @map("start_time")
  endTime      String                @map("end_time")
  slotDuration Int                   @default(60) @map("slot_duration")
  pricePerSlot Decimal               @map("price_per_slot") @db.Decimal(10, 2)
  currency     Currency              @default(EGP)
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  bookings     ConsultationBooking[]
  instructor   User                  @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, dayOfWeek])
  @@index([instructorId])
  @@index([isActive])
  @@map("instructor_availabilities")
}

model ConsultationBooking {
  id              String                 @id @default(cuid())
  studentId       String                 @map("student_id")
  availabilityId  String                 @map("availability_id")
  paymentId       String?                @unique @map("payment_id")
  status          BookingStatus          @default(PENDING)
  scheduledAt     DateTime               @map("scheduled_at")
  durationMinutes Int                    @map("duration_minutes")
  googleMeetLink  String?                @map("google_meet_link")
  notes           String?
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  availability    InstructorAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  payment         Payment?               @relation(fields: [paymentId], references: [id])
  student         User                   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([availabilityId])
  @@index([status])
  @@index([scheduledAt])
  @@map("consultation_bookings")
}

model GoogleCalendarToken {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  scope        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_calendar_tokens")
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  UNDER_REVIEW
}

enum CourseVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum Currency {
  USD
  EGP
}

enum PaymentProvider {
  PAYMOB
  STRIPE
  PAYPAL
}

enum LectureType {
  VIDEO
  TEXT
  AUDIO
  QUIZ
  ASSIGNMENT
  LIVE_SESSION
  ATTACHMENT
}

enum AttachmentType {
  PDF
  VIDEO
  IMAGE
  DOC
  DOCX
  PPT
  PPTX
  XLS
  XLSX
  ZIP
  AUDIO
  LINK
  TEXT
  CODE
  HTML
  OTHER
}

enum PathSectionType {
  TITLE
  PARAGRAPH
  IMAGE
  BUTTON
}

enum PathCategory {
  WEB
  MOBILE
  OTHER
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

enum RefundStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}
